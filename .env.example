# Upstash Redis (REST) — use the same KV_REST_* values as ventrapos if sharing one database.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Venue relay token (long random string). Used for:
# - QR menu ↔ POS (/api/qr-orders/*, ?qr_t= on menu URLs)
# - POS ↔ kitchen board (/api/kitchen-tickets/*) — any browser can run KLD
NEXT_PUBLIC_QR_ORDER_RELAY_TOKEN=

# Optional separate kitchen token (defaults to NEXT_PUBLIC_QR_ORDER_RELAY_TOKEN)
# NEXT_PUBLIC_KITCHEN_RELAY_TOKEN=

# Optional — required where Supabase client is instantiated.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
